  "database_models": {
    "User": {
      "fields": [
        "id",
        "username",
        "email",
        "password",
        "first_name",
        "last_name",
        "language",
        "currency",
        "is_setup_complete"
      ],
      "relationships": [
        "OneToOne: AccountBalance, UserProfile",
        "ForeignKey: Transactions, Budgets, Trackers"
      ]
    },
    "AccountBalance": {
      "fields": [
        "id",
        "user",
        "current_balance",
        "total_income",
        "total_expenses",
        "total_savings"
      ],
      "relationships": [
        "OneToOne: User"
      ]
    },
    "Transaction": {
      "fields": [
        "id",
        "user",
        "transaction_type",
        "category",
        "amount",
        "description",
        "notes",
        "date",
        "shopping_group",
        "is_recurring"
      ],
      "relationships": [
        "ForeignKey: User"
      ]
    },
    "MonthlyBudget": {
      "fields": [
        "id",
        "user",
        "month",
        "year",
        "planned_income",
        "actual_income",
        "planned_fixed_expenses",
        "actual_fixed_expenses",
        "planned_survival",
        "actual_survival",
        "planned_optional",
        "actual_optional",
        "planned_culture",
        "actual_culture",
        "planned_extra",
        "actual_extra",
        "planned_savings",
        "actual_savings"
      ],
      "relationships": [
        "ForeignKey: User",
        "OneToMany: WeeklyBudget"
      ]
    },
    "WeeklyBudget": {
      "fields": [
        "id",
        "monthly_budget",
        "week_number",
        "start_date",
        "end_date",
        "planned/actual for each category"
      ],
      "relationships": [
        "ForeignKey: MonthlyBudget"
      ]
    },
    "SavingsTracker": {
      "fields": [
        "id",
        "user",
        "name",
        "target_amount",
        "current_amount",
        "target_date",
        "description",
        "is_completed"
      ],
      "relationships": [
        "ForeignKey: User"
      ]
    }
  },
