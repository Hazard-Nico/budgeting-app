  "api_endpoints": {
    "authentication": [
      "POST /api/auth/register/ - User registration",
      "POST /api/auth/login/ - User login (JWT)",
      "POST /api/auth/token/refresh/ - Refresh access token",
      "GET /api/auth/me/ - Get current user",
      "PUT /api/auth/me/ - Update user profile",
      "GET /api/auth/profile/ - Get user profile",
      "PUT /api/auth/profile/ - Update user profile",
      "GET /api/auth/balance/ - Get account balance",
      "POST /api/auth/complete-setup/ - Mark setup as complete"
    ],
    "transactions": [
      "GET /api/transactions/ - List transactions",
      "POST /api/transactions/ - Create transaction",
      "GET /api/transactions/{id}/ - Get transaction detail",
      "PUT /api/transactions/{id}/ - Update transaction",
      "DELETE /api/transactions/{id}/ - Delete transaction",
      "GET /api/transactions/by_category/ - Group by category",
      "GET /api/transactions/summary/ - Get summary"
    ],
    "incomes": [
      "GET /api/incomes/ - List incomes",
      "POST /api/incomes/ - Create income",
      "GET /api/incomes/{id}/ - Get income detail",
      "PUT /api/incomes/{id}/ - Update income",
      "DELETE /api/incomes/{id}/ - Delete income"
    ],
    "fixed_expenses": [
      "GET /api/fixed-expenses/ - List fixed expenses",
      "POST /api/fixed-expenses/ - Create fixed expense",
      "GET /api/fixed-expenses/{id}/ - Get fixed expense detail",
      "PUT /api/fixed-expenses/{id}/ - Update fixed expense",
      "DELETE /api/fixed-expenses/{id}/ - Delete fixed expense",
      "GET /api/fixed-expenses/upcoming/ - Get upcoming expenses"
    ],
    "budgets": [
